---
import { getCollection, getEntry, render } from 'astro:content';
import ChapterLayout from '../../layouts/ChapterLayout.astro';

export async function getStaticPaths() {
  const chapters = await getCollection('chapters', ({ data }) => !data.draft);
  return chapters.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

/* Every chapter must ship with its practice data — fail the build loudly if
   any of the three files is missing. */
const [cardsEntry, quizEntry, assignmentsEntry] = await Promise.all([
  getEntry('flashcards', entry.id),
  getEntry('quizzes', entry.id),
  getEntry('assignments', entry.id),
]);

for (const [name, value] of [
  ['flashcards', cardsEntry],
  ['quizzes', quizEntry],
  ['assignments', assignmentsEntry],
] as const) {
  if (!value) {
    throw new Error(
      `Chapter "${entry.id}" is missing src/content/${name}/${entry.id}.yaml — every chapter needs all three practice files.`
    );
  }
}

const { Content, headings } = await render(entry);
---

<ChapterLayout
  chapter={entry.data.chapter}
  slug={entry.id}
  title={entry.data.title}
  description={entry.data.description}
  readingMinutes={entry.data.readingMinutes}
  keyTakeaways={entry.data.keyTakeaways}
  references={entry.data.references}
  headings={headings}
  cards={cardsEntry!.data.cards}
  questions={quizEntry!.data.questions}
  assignments={assignmentsEntry!.data.assignments}
>
  <Content />
</ChapterLayout>
