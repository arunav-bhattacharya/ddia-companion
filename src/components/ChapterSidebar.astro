---
import { CHAPTERS, GROUPS } from '../lib/chapters';

const path = Astro.url.pathname;
const groups = GROUPS.map((group) => ({
  group,
  chapters: CHAPTERS.filter((c) => c.group === group),
}));
---

<div id="drawer-backdrop" hidden></div>
<aside id="chapter-drawer" class="ui" aria-label="Chapter navigation" aria-hidden="true">
  <div class="drawer-head">
    <span class="drawer-title">Chapters</span>
    <button id="drawer-close" type="button" aria-label="Close chapter navigation">✕</button>
  </div>
  <nav>
    {
      groups.map(({ group, chapters }) => (
        <div class="group">
          <p class="group-label">{group}</p>
          <ol>
            {chapters.map((c) => {
              const href = `/chapters/${c.slug}/`;
              const active = path.startsWith(href);
              return (
                <li>
                  <a href={href} aria-current={active ? 'page' : undefined}>
                    <span class="n">{String(c.chapter).padStart(2, '0')}</span>
                    <span>{c.title}</span>
                  </a>
                </li>
              );
            })}
          </ol>
        </div>
      ))
    }
    <a class="extra" href="/glossary/">Glossary</a>
  </nav>
</aside>

<style>
  #drawer-backdrop {
    position: fixed;
    inset: 0;
    z-index: 70;
    background: rgb(0 0 0 / 0.35);
  }

  #drawer-backdrop[hidden] {
    display: none;
  }

  #chapter-drawer {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 71;
    width: min(20rem, 85vw);
    background: var(--surface);
    border-right: 1px solid var(--border-strong);
    transform: translateX(-100%);
    transition: transform 200ms ease;
    overflow-y: auto;
    padding: var(--space-4) var(--space-4) var(--space-6);
    visibility: hidden;
  }

  #chapter-drawer.open {
    transform: translateX(0);
    visibility: visible;
  }

  @media (prefers-reduced-motion: reduce) {
    #chapter-drawer {
      transition: none;
    }
  }

  .drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }

  .drawer-title {
    font-weight: 600;
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-faint);
  }

  #drawer-close {
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  #drawer-close:hover {
    color: var(--text);
    border-color: var(--border-strong);
  }

  .group {
    margin-bottom: var(--space-4);
  }

  .group-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-faint);
    margin-bottom: var(--space-2);
  }

  ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 2px;
  }

  li a {
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
    padding: var(--space-2) var(--space-2);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: 1.35;
  }

  li a:hover {
    background: var(--accent-subtle);
    color: var(--text);
  }

  li a[aria-current='page'] {
    background: var(--accent-subtle);
    color: var(--accent-text);
    font-weight: 600;
  }

  .n {
    font-variant-numeric: tabular-nums;
    font-size: var(--text-xs);
    color: var(--text-faint);
    flex-shrink: 0;
  }

  li a[aria-current='page'] .n {
    color: var(--accent-text);
  }

  .extra {
    display: block;
    margin-top: var(--space-2);
    padding: var(--space-2);
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .extra:hover {
    color: var(--text);
  }
</style>

<script>
  const drawer = document.getElementById('chapter-drawer')!;
  const backdrop = document.getElementById('drawer-backdrop')!;
  const toggle = document.getElementById('sidebar-toggle');
  const close = document.getElementById('drawer-close')!;

  function setOpen(open: boolean) {
    drawer.classList.toggle('open', open);
    drawer.setAttribute('aria-hidden', String(!open));
    backdrop.hidden = !open;
    toggle?.setAttribute('aria-expanded', String(open));
    if (open) {
      drawer.querySelector<HTMLElement>('a[aria-current="page"]')?.scrollIntoView({ block: 'center' });
    }
  }

  toggle?.addEventListener('click', () => setOpen(!drawer.classList.contains('open')));
  close.addEventListener('click', () => setOpen(false));
  backdrop.addEventListener('click', () => setOpen(false));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer.classList.contains('open')) setOpen(false);
  });
</script>
