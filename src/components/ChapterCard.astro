---
import { withBase } from '../lib/url';

interface Props {
  chapter: number;
  slug: string;
  title: string;
  description?: string;
  readingMinutes?: number;
  available: boolean;
}

const { chapter, slug, title, description, readingMinutes, available } = Astro.props;
---

{
  available ? (
    <a class="card" href={withBase(`/chapters/${slug}/`)} data-chapter-card={slug}>
      <span class="num" aria-hidden="true">
        {String(chapter).padStart(2, '0')}
      </span>
      <span class="body">
        <span class="title">{title}</span>
        {description && <span class="desc">{description}</span>}
        <span class="meta ui">
          {readingMinutes && <span>{readingMinutes} min</span>}
          <span class="progress" data-progress-label />
        </span>
      </span>
    </a>
  ) : (
    <div class="card pending">
      <span class="num" aria-hidden="true">
        {String(chapter).padStart(2, '0')}
      </span>
      <span class="body">
        <span class="title">{title}</span>
        <span class="meta ui">
          <span>In the works</span>
        </span>
      </span>
    </div>
  )
}

<style>
  .card {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-5);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--gradient-surface);
    text-decoration: none;
    color: var(--text);
    transition: border-color 120ms, transform 120ms, background 160ms;
    height: 100%;
  }

  a.card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
    background: var(--gradient-surface-hover);
  }

  .pending {
    opacity: 0.6;
  }

  .num {
    font-family: var(--font-body);
    font-size: var(--text-2xl);
    font-weight: 700;
    line-height: 1;
    color: var(--border-strong);
    background: var(--gradient-numeral);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    opacity: 0.55;
    transition: opacity 160ms;
    flex-shrink: 0;
  }

  a.card:hover .num {
    opacity: 1;
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
  }

  .title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-md);
    line-height: 1.3;
  }

  .desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.55;
  }

  .meta {
    margin-top: auto;
    padding-top: var(--space-2);
    display: flex;
    gap: var(--space-3);
    font-size: var(--text-xs);
    color: var(--text-faint);
  }

  .progress:empty {
    display: none;
  }

  .progress {
    color: var(--ok);
    font-weight: 600;
  }
</style>
