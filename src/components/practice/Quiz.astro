---
interface Question {
  id: string;
  prompt: string;
  options: string[];
  answerIndex: number;
  explanation: string;
}

interface Props {
  chapterSlug: string;
  questions: Question[];
}

const { chapterSlug, questions } = Astro.props;

/* Only what grading needs goes into the JSON island; prompts/options are
   already in the DOM. */
const grading = questions.map((q) => ({
  id: q.id,
  answerIndex: q.answerIndex,
}));
---

<chapter-quiz class="ui" data-chapter={chapterSlug} data-total={questions.length}>
  <p class="status" aria-live="polite"></p>

  <ol class="questions">
    {
      questions.map((q, qi) => (
        <li class="question" data-question-id={q.id}>
          <p class="prompt">{q.prompt}</p>
          <div class="options" role="group" aria-label={`Options for question ${qi + 1}`}>
            {q.options.map((opt, oi) => (
              <button type="button" class="option" data-option-index={oi}>
                <span class="key">{String.fromCharCode(65 + oi)}</span>
                <span>{opt}</span>
              </button>
            ))}
          </div>
          <div class="explanation" hidden>
            <p class="verdict-line" />
            <p>{q.explanation}</p>
          </div>
        </li>
      ))
    }
  </ol>

  <div class="summary" hidden>
    <p class="score"></p>
    <p class="best"></p>
    <button type="button" data-action="retry">Try again</button>
  </div>

  <script is:inline type="application/json" set:html={JSON.stringify(grading)} />
</chapter-quiz>

<style>
  chapter-quiz {
    display: block;
  }

  .status {
    font-size: var(--text-sm);
    color: var(--text-faint);
    margin-bottom: var(--space-4);
    font-variant-numeric: tabular-nums;
  }

  .questions {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-6);
    counter-reset: q;
  }

  .question {
    counter-increment: q;
  }

  .prompt {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: var(--text-md);
    margin-bottom: var(--space-4);
  }

  .prompt::before {
    content: counter(q) '. ';
    color: var(--accent);
  }

  .options {
    display: grid;
    gap: var(--space-2);
  }

  .option {
    display: flex;
    gap: var(--space-3);
    align-items: baseline;
    text-align: left;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    line-height: 1.5;
    transition: border-color 120ms;
  }

  .option:hover:not(:disabled) {
    border-color: var(--accent);
  }

  .option:disabled {
    cursor: default;
    opacity: 0.75;
  }

  .option .key {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-faint);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    width: 1.4rem;
    height: 1.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    align-self: center;
  }

  .option.correct {
    border-color: var(--ok);
    background: var(--ok-subtle);
    opacity: 1;
  }

  .option.correct .key {
    border-color: var(--ok);
    color: var(--ok);
  }

  .option.incorrect {
    border-color: var(--err);
    background: var(--err-subtle);
    opacity: 1;
  }

  .option.incorrect .key {
    border-color: var(--err);
    color: var(--err);
  }

  .explanation {
    margin-top: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-left: 3px solid var(--border-strong);
    background: var(--surface);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .verdict-line {
    font-weight: 600;
    margin-bottom: var(--space-1);
  }

  .explanation.right {
    border-left-color: var(--ok);
  }

  .explanation.right .verdict-line {
    color: var(--ok);
  }

  .explanation.wrong {
    border-left-color: var(--err);
  }

  .explanation.wrong .verdict-line {
    color: var(--err);
  }

  .summary {
    margin-top: var(--space-6);
    padding: var(--space-5);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    background: var(--surface);
    text-align: center;
  }

  .summary .score {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 600;
  }

  .summary .best {
    color: var(--text-muted);
    font-size: var(--text-sm);
    margin-top: var(--space-1);
  }

  .summary button {
    margin-top: var(--space-4);
    padding: var(--space-2) var(--space-5);
    border: 1px solid var(--accent);
    color: var(--accent-text);
    border-radius: var(--radius-md);
    font-weight: 600;
  }

  .summary button:hover {
    background: var(--accent-subtle);
  }
</style>

<script>
  import '../../scripts/quiz';
</script>
