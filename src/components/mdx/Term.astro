---
/* Links a term to its glossary entry: <Term id="lsm-tree">LSM-tree</Term> */
import { withBase } from '../../lib/url';

interface Props {
  id: string;
}

const { id } = Astro.props;
---

<a class="term" href={withBase(`/glossary/#${id}`)}><slot /></a>

<style>
  .term {
    color: inherit;
    text-decoration-style: dotted;
    text-decoration-color: var(--accent);
  }

  .term:hover {
    color: var(--accent-text);
  }
</style>
