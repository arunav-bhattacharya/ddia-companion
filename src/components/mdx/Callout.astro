---
/* In-prose callout. Types:
   - note: neutral aside, extra context
   - insight: the "aha" — a connection worth remembering
   - warning: common misconception or production trap
   - example: a concrete worked example or analogy */

interface Props {
  type?: 'note' | 'insight' | 'warning' | 'example';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const defaultTitles: Record<string, string> = {
  note: 'Note',
  insight: 'Key insight',
  warning: 'Watch out',
  example: 'Example',
};

const heading = title ?? defaultTitles[type];
---

<aside class={`callout callout-${type}`}>
  <p class="callout-title ui">{heading}</p>
  <div class="callout-body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    background: var(--gradient-surface);
  }

  .callout-warning {
    border-left-color: var(--err);
  }

  .callout-insight {
    border-left-color: var(--accent);
    background: var(--gradient-accent-subtle);
  }

  .callout-example {
    border-left-color: var(--ok);
  }

  .callout-title {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-bottom: var(--space-2);
  }

  .callout-body {
    font-size: 0.97em;
  }

  .callout-body :global(> * + *) {
    margin-top: var(--space-3);
  }
</style>
