---
import Diagram from '../Diagram.astro';

const calls = [
  { label: 'profile service', width: 120 },
  { label: 'posts service', width: 150 },
  { label: 'ads service', width: 100 },
  { label: 'recommendations', width: 460, slow: true },
  { label: 'notifications', width: 135 },
];
---

<Diagram caption="Tail latency amplification: the page needs all five parallel backend calls, so the slowest one sets the response time — even though four of them were quick.">
  <svg viewBox="0 0 720 260" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="tail-title">
    <title id="tail-title">Five parallel backend calls where one slow call delays the whole request</title>

    <text x="20" y="28" font-size="13" font-weight="600" fill="var(--diagram-stroke)">one user request → five parallel backend calls</text>

    {
      calls.map((c, i) => {
        const y = 50 + i * 34;
        return (
          <g>
            <rect
              x="180"
              y={y}
              width={c.width}
              height="22"
              rx="4"
              fill={c.slow ? 'var(--diagram-accent)' : 'var(--diagram-fill)'}
              stroke={c.slow ? 'var(--diagram-accent)' : 'var(--diagram-muted)'}
              stroke-width="1.5"
            />
            <text x="170" y={y + 16} text-anchor="end" font-size="12" fill="var(--diagram-muted)">
              {c.label}
            </text>
          </g>
        );
      })
    }

    <text x="652" y="186" text-anchor="middle" font-size="12" font-weight="600" fill="var(--diagram-accent)">the straggler</text>

    <!-- Total response time bracket -->
    <line x1="180" y1="232" x2="640" y2="232" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <line x1="180" y1="226" x2="180" y2="238" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <line x1="640" y1="226" x2="640" y2="238" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="410" y="252" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">user-visible response time = the slowest call</text>
  </svg>
</Diagram>
