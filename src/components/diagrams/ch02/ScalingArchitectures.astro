---
import Diagram from '../Diagram.astro';
---

<Diagram
  caption="Three ways to add horsepower: one bigger machine (shared memory), several machines around one disk array (shared disk), or fully independent nodes that talk over the network (shared nothing)."
  wide
>
  <svg viewBox="0 0 760 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="arch-title">
    <title id="arch-title">Shared-memory, shared-disk, and shared-nothing architectures side by side</title>

    <!-- Shared memory -->
    <text x="130" y="26" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">Shared memory</text>
    <text x="130" y="44" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">scale up: one big box</text>
    <rect x="40" y="60" width="180" height="170" rx="8" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <rect x="58" y="78" width="64" height="34" rx="4" fill="none" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="90" y="99" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">CPUs</text>
    <rect x="138" y="78" width="64" height="34" rx="4" fill="none" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="170" y="99" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">RAM</text>
    <rect x="58" y="130" width="144" height="34" rx="4" fill="none" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="130" y="151" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">disks</text>
    <text x="130" y="208" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">cost grows faster</text>
    <text x="130" y="222" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">than linearly</text>

    <!-- Shared disk -->
    <text x="380" y="26" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">Shared disk</text>
    <text x="380" y="44" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">many CPUs, one storage array</text>
    <rect x="300" y="60" width="70" height="48" rx="4" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="335" y="88" text-anchor="middle" font-size="11" fill="var(--diagram-stroke)">CPU+RAM</text>
    <rect x="390" y="60" width="70" height="48" rx="4" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="425" y="88" text-anchor="middle" font-size="11" fill="var(--diagram-stroke)">CPU+RAM</text>
    <rect x="330" y="170" width="100" height="44" rx="4" fill="none" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="380" y="196" text-anchor="middle" font-size="11" fill="var(--diagram-stroke)">NAS / SAN</text>
    <line x1="335" y1="108" x2="368" y2="168" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <line x1="425" y1="108" x2="392" y2="168" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="380" y="240" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">locking contention</text>
    <text x="380" y="254" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">limits scaling</text>

    <!-- Shared nothing -->
    <text x="630" y="26" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">Shared nothing</text>
    <text x="630" y="44" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">scale out: independent nodes</text>
    {
      [0, 1, 2].map((i) => {
        const x = 540 + i * 64;
        return (
          <g>
            <rect x={x} y="60" width="54" height="92" rx="4" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5" />
            <text x={x + 27} y="86" text-anchor="middle" font-size="10" fill="var(--diagram-stroke)">CPU</text>
            <text x={x + 27} y="104" text-anchor="middle" font-size="10" fill="var(--diagram-stroke)">RAM</text>
            <text x={x + 27} y="122" text-anchor="middle" font-size="10" fill="var(--diagram-stroke)">disk</text>
          </g>
        );
      })
    }
    <line x1="540" y1="180" x2="726" y2="180" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="5 4"/>
    {
      [0, 1, 2].map((i) => (
        <line x1={567 + i * 64} y1="152" x2={567 + i * 64} y2="180" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="5 4" />
      ))
    }
    <text x="630" y="202" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">coordination via network</text>
    <text x="630" y="240" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">potential for linear scaling,</text>
    <text x="630" y="254" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">at the price of distribution</text>
  </svg>
</Diagram>
