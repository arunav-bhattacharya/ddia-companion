---
import Diagram from '../Diagram.astro';

/* Response times for a sample of requests, sorted fastest -> slowest, with
   the median, p95, and p99 picked out. Heights are hand-tuned to look like a
   realistic long-tail distribution. */
const heights = [
  18, 20, 21, 22, 23, 24, 24, 25, 26, 27, 28, 28, 29, 30, 31, 32, 33, 34, 35,
  36, 38, 39, 41, 43, 45, 47, 50, 53, 56, 60, 64, 69, 75, 82, 91, 102, 118,
  142, 178, 232,
];
const barWidth = 13;
const gap = 3;
const baseY = 270;
const startX = 50;
---

<Diagram caption="Sort all response times from fastest to slowest and read off the percentiles: half of requests beat the median; the tail tells you how bad the worst experiences are.">
  <svg viewBox="0 0 720 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="pct-title">
    <title id="pct-title">Bar chart of sorted response times with median, p95, and p99 markers</title>

    <!-- Axis -->
    <line x1="40" y1={baseY} x2="700" y2={baseY} stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="40" y="295" font-size="12" fill="var(--diagram-muted)">fastest</text>
    <text x="700" y="295" text-anchor="end" font-size="12" fill="var(--diagram-muted)">slowest</text>
    <text x="370" y="313" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">requests, sorted by response time</text>

    {
      heights.map((h, i) => {
        const x = startX + i * (barWidth + gap);
        const isMedian = i === 19;
        const isP95 = i === 37;
        const isP99 = i === 39;
        const highlight = isMedian || isP95 || isP99;
        return (
          <rect
            x={x}
            y={baseY - h}
            width={barWidth}
            height={h}
            fill={highlight ? 'var(--diagram-accent)' : 'var(--diagram-fill)'}
            stroke={highlight ? 'var(--diagram-accent)' : 'var(--diagram-muted)'}
            stroke-width="1"
          />
        );
      })
    }

    <!-- Median marker -->
    <line x1={startX + 19 * (barWidth + gap) + 6} y1={baseY - 36 - 12} x2={startX + 19 * (barWidth + gap) + 6} y2="90" stroke="var(--diagram-accent)" stroke-width="1.5" stroke-dasharray="4 4"/>
    <text x={startX + 19 * (barWidth + gap) + 6} y="78" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-accent)">median (p50)</text>
    <text x={startX + 19 * (barWidth + gap) + 6} y="62" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">half of requests are faster</text>

    <!-- p95 marker -->
    <line x1={startX + 37 * (barWidth + gap) + 6} y1={baseY - 142 - 12} x2={startX + 37 * (barWidth + gap) + 6} y2="56" stroke="var(--diagram-accent)" stroke-width="1.5" stroke-dasharray="4 4"/>
    <text x={startX + 37 * (barWidth + gap) + 6} y="44" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-accent)">p95</text>

    <!-- p99 marker -->
    <line x1={startX + 39 * (barWidth + gap) + 6} y1={baseY - 232 - 8} x2={startX + 39 * (barWidth + gap) + 6} y2="22" stroke="var(--diagram-accent)" stroke-width="1.5" stroke-dasharray="4 4"/>
    <text x={startX + 39 * (barWidth + gap) + 2} y="14" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-accent)">p99 — the tail</text>
  </svg>
</Diagram>
