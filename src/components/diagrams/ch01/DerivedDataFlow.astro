---
import Diagram from '../Diagram.astro';
---

<Diagram caption="One system of record feeds many derived datasets. Each derived copy is redundant — and rebuildable from the source if it is ever lost.">
  <svg viewBox="0 0 720 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="derived-data-title">
    <title id="derived-data-title">A system of record with derived data systems built from it</title>

    <!-- System of record -->
    <rect x="30" y="100" width="190" height="96" rx="8" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="125" y="134" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">System of record</text>
    <text x="125" y="156" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">authoritative copy —</text>
    <text x="125" y="172" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">writes land here first</text>

    <text x="125" y="226" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">lost a derived copy?</text>
    <text x="125" y="242" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">rebuild it from here</text>

    <!-- Derivation arrows -->
    <line x1="220" y1="122" x2="462" y2="44" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="458,38 470,42 461,50" fill="var(--diagram-accent)"/>
    <line x1="220" y1="138" x2="462" y2="110" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="459,104 470,110 460,116" fill="var(--diagram-accent)"/>
    <line x1="220" y1="158" x2="462" y2="184" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="460,178 470,186 459,190" fill="var(--diagram-accent)"/>
    <line x1="220" y1="174" x2="462" y2="252" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="461,246 470,254 458,258" fill="var(--diagram-accent)"/>

    <text x="340" y="86" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">transform / process</text>

    <!-- Derived systems -->
    <rect x="470" y="20" width="220" height="48" rx="6" fill="var(--diagram-accent)" fill-opacity="0.10" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="580" y="40" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Cache</text>
    <text x="580" y="57" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">cheap repeated reads</text>

    <rect x="470" y="88" width="220" height="48" rx="6" fill="var(--diagram-accent)" fill-opacity="0.10" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="580" y="108" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Search index</text>
    <text x="580" y="125" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">keyword lookups</text>

    <rect x="470" y="156" width="220" height="48" rx="6" fill="var(--diagram-accent)" fill-opacity="0.10" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="580" y="176" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Materialized view</text>
    <text x="580" y="193" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">precomputed query results</text>

    <rect x="470" y="224" width="220" height="48" rx="6" fill="var(--diagram-accent)" fill-opacity="0.10" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="580" y="244" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Warehouse / ML model</text>
    <text x="580" y="261" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">analytics copy, trained model</text>
  </svg>
</Diagram>
