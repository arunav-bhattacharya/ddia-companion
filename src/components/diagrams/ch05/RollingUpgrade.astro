---
import Diagram from '../Diagram.astro';
---

<Diagram caption="During a rolling upgrade, old and new code read and write the same database at the same time — and the database still holds records encoded years ago. Data outlives code.">
  <svg viewBox="0 0 720 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="rollup-title">
    <title id="rollup-title">A rolling upgrade with mixed code versions sharing one database full of records written at different times</title>

    <!-- App instances -->
    <text x="360" y="28" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">App servers, mid rolling upgrade</text>

    <rect x="80" y="44" width="140" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="150" y="68" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">node 1 — v8</text>
    <text x="150" y="86" text-anchor="middle" font-size="11" fill="var(--diagram-accent)">upgraded</text>

    <rect x="290" y="44" width="140" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="360" y="68" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">node 2 — v8</text>
    <text x="360" y="86" text-anchor="middle" font-size="11" fill="var(--diagram-accent)">upgraded</text>

    <rect x="500" y="44" width="140" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="570" y="68" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">node 3 — v7</text>
    <text x="570" y="86" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">not yet</text>

    <!-- Arrows to DB -->
    <line x1="150" y1="100" x2="290" y2="172" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="284,166 294,175 280,177" fill="var(--diagram-accent)"/>
    <text x="172" y="148" font-size="11" fill="var(--diagram-accent)">writes v8 format</text>

    <line x1="570" y1="100" x2="430" y2="172" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <polygon points="440,177 426,175 436,166" fill="var(--diagram-stroke)"/>
    <text x="548" y="148" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">reads — must ignore v8 fields</text>
    <text x="548" y="163" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">(forward compatibility)</text>

    <!-- Database -->
    <rect x="180" y="180" width="360" height="116" rx="8" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="360" y="204" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">one database, many eras</text>

    <rect x="200" y="216" width="150" height="30" rx="4" fill="var(--bg)" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="275" y="236" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">row written 5 years ago (v2)</text>

    <rect x="370" y="216" width="150" height="30" rx="4" fill="var(--bg)" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="445" y="236" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">row written 5 days ago (v7)</text>

    <rect x="285" y="254" width="150" height="30" rx="4" fill="var(--bg)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="360" y="274" text-anchor="middle" font-size="11" fill="var(--diagram-accent)">row written 5 ms ago (v8)</text>
  </svg>
</Diagram>
