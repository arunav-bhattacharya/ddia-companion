---
import Diagram from '../Diagram.astro';
---

<Diagram caption="Avro schema resolution: the reader compares the writer's schema with its own, matching fields by name — extra fields are ignored, missing ones are filled with the reader's defaults.">
  <svg viewBox="0 0 720 330" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="avrores-title">
    <title id="avrores-title">An Avro reader resolving differences between the writer's schema and its own reader's schema</title>

    <!-- Writer's schema column -->
    <text x="130" y="34" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Writer's schema (v2, newer)</text>
    <rect x="30" y="50" width="200" height="40" rx="5" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="130" y="75" text-anchor="middle" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">interests</text>
    <rect x="30" y="100" width="200" height="40" rx="5" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="130" y="125" text-anchor="middle" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">userName</text>
    <rect x="30" y="150" width="200" height="40" rx="5" fill="var(--diagram-fill)" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="5 4"/>
    <text x="130" y="175" text-anchor="middle" font-size="12" font-family="monospace" fill="var(--diagram-muted)">photoURL</text>

    <!-- Reader's schema column -->
    <text x="590" y="34" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Reader's schema (v1, older)</text>
    <rect x="490" y="50" width="200" height="40" rx="5" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="590" y="75" text-anchor="middle" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">userName</text>
    <rect x="490" y="100" width="200" height="40" rx="5" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="590" y="125" text-anchor="middle" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">interests</text>
    <rect x="490" y="150" width="200" height="40" rx="5" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="590" y="170" text-anchor="middle" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">favoriteNumber</text>
    <text x="590" y="184" text-anchor="middle" font-size="11" fill="var(--diagram-accent)">default: null</text>

    <!-- Match lines (by name, order doesn't matter) -->
    <line x1="230" y1="70" x2="482" y2="120" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <polygon points="480,113 490,121 478,124" fill="var(--diagram-stroke)"/>
    <line x1="230" y1="120" x2="482" y2="70" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <polygon points="478,66 490,69 480,77" fill="var(--diagram-stroke)"/>
    <text x="360" y="56" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">matched by field name —</text>
    <text x="360" y="71" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">order is irrelevant</text>

    <!-- Ignored field -->
    <line x1="230" y1="170" x2="330" y2="170" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="5 4"/>
    <text x="338" y="174" font-size="11" fill="var(--diagram-muted)">unknown to reader → ignored</text>

    <!-- Default fill -->
    <line x1="482" y1="200" x2="400" y2="240" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="392" y="262" text-anchor="middle" font-size="11" fill="var(--diagram-accent)">absent from writer's data →</text>
    <text x="392" y="278" text-anchor="middle" font-size="11" fill="var(--diagram-accent)">filled in with the reader's default value</text>

    <text x="360" y="316" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">The reader needs BOTH schemas: bytes alone carry no field names or types.</text>
  </svg>
</Diagram>
