---
import Diagram from '../Diagram.astro';
---

<Diagram caption="Three indistinguishable failures: whether the request was lost, the remote node is down, or the response was lost, the client sees exactly the same thing — silence.">
  <svg viewBox="0 0 740 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="reqfail-title">
    <title id="reqfail-title">Three scenarios — request lost, node down, response lost — that all look identical to the waiting client</title>

    <!-- Scenario (a): request lost -->
    <g>
      <text x="120" y="24" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">(a) request lost</text>
      <rect x="30" y="40" width="70" height="26" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="65" y="57" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">client</text>
      <rect x="140" y="40" width="70" height="26" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="175" y="57" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">node</text>
      <line x1="65" y1="66" x2="65" y2="250" stroke="var(--diagram-muted)" stroke-width="1.5"/>
      <line x1="175" y1="66" x2="175" y2="250" stroke="var(--diagram-muted)" stroke-width="1.5"/>
      <line x1="65" y1="95" x2="118" y2="115" stroke="var(--diagram-stroke)" stroke-width="1.5" stroke-dasharray="5 4"/>
      <text x="120" y="124" text-anchor="middle" font-size="15" font-weight="700" fill="var(--diagram-accent)">&#215;</text>
      <text x="92" y="88" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">request</text>
    </g>

    <!-- Scenario (b): node down -->
    <g>
      <text x="370" y="24" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">(b) node down or paused</text>
      <rect x="280" y="40" width="70" height="26" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="315" y="57" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">client</text>
      <rect x="390" y="40" width="70" height="26" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="425" y="57" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">node</text>
      <line x1="315" y1="66" x2="315" y2="250" stroke="var(--diagram-muted)" stroke-width="1.5"/>
      <line x1="425" y1="66" x2="425" y2="110" stroke="var(--diagram-muted)" stroke-width="1.5"/>
      <line x1="315" y1="95" x2="425" y2="135" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="345" y="88" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">request</text>
      <rect x="412" y="115" width="26" height="80" rx="4" fill="var(--diagram-accent)" opacity="0.25"/>
      <text x="425" y="212" text-anchor="middle" font-size="11" fill="var(--diagram-accent)">crashed /</text>
      <text x="425" y="226" text-anchor="middle" font-size="11" fill="var(--diagram-accent)">paused</text>
    </g>

    <!-- Scenario (c): response lost -->
    <g>
      <text x="620" y="24" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">(c) response lost</text>
      <rect x="530" y="40" width="70" height="26" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="565" y="57" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">client</text>
      <rect x="640" y="40" width="70" height="26" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="675" y="57" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">node</text>
      <line x1="565" y1="66" x2="565" y2="250" stroke="var(--diagram-muted)" stroke-width="1.5"/>
      <line x1="675" y1="66" x2="675" y2="250" stroke="var(--diagram-muted)" stroke-width="1.5"/>
      <line x1="565" y1="95" x2="675" y2="135" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="595" y="88" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">request</text>
      <text x="700" y="152" text-anchor="start" font-size="11" fill="var(--diagram-muted)">processed!</text>
      <line x1="675" y1="160" x2="622" y2="180" stroke="var(--diagram-stroke)" stroke-width="1.5" stroke-dasharray="5 4"/>
      <text x="618" y="190" text-anchor="middle" font-size="15" font-weight="700" fill="var(--diagram-accent)">&#215;</text>
      <text x="652" y="200" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">response</text>
    </g>

    <!-- shared bottom annotation -->
    <text x="370" y="284" text-anchor="middle" font-size="12" font-weight="600" fill="var(--diagram-accent)">the client sees the same thing in all three cases: no response</text>
  </svg>
</Diagram>
