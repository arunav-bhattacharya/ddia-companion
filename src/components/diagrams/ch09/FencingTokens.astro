---
import Diagram from '../Diagram.astro';
---

<Diagram caption="Fencing tokens fix the lease bug: the lock service hands out an increasing number with every grant, and the storage service rejects any write carrying an older token than one it has already seen." wide>
  <svg viewBox="0 0 740 310" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="fencing-title">
    <title id="fencing-title">Timeline showing the lock service granting tokens 33 and 34, and the storage service rejecting the stale write with token 33</title>

    <!-- lane labels -->
    <text x="20" y="56" font-size="12" font-weight="600" fill="var(--diagram-stroke)">lock service</text>
    <text x="20" y="136" font-size="12" font-weight="600" fill="var(--diagram-stroke)">client 1</text>
    <text x="20" y="206" font-size="12" font-weight="600" fill="var(--diagram-stroke)">client 2</text>
    <text x="20" y="276" font-size="12" font-weight="600" fill="var(--diagram-stroke)">storage</text>

    <!-- lanes -->
    <line x1="110" y1="52" x2="720" y2="52" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <line x1="110" y1="132" x2="184" y2="132" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <line x1="386" y1="132" x2="534" y2="132" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <line x1="666" y1="132" x2="720" y2="132" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <line x1="110" y1="202" x2="720" y2="202" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <line x1="110" y1="272" x2="720" y2="272" stroke="var(--diagram-muted)" stroke-width="1.5"/>

    <!-- grant token 33 to client 1 -->
    <line x1="150" y1="52" x2="170" y2="126" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <path d="M 170 126 l -7 -4 l 5 -6 z" fill="var(--diagram-stroke)"/>
    <rect x="174" y="64" width="92" height="20" rx="4" fill="var(--diagram-fill)" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="220" y="78" text-anchor="middle" font-size="11" fill="var(--diagram-stroke)">lease, token 33</text>

    <!-- client 1 pause -->
    <rect x="190" y="118" width="190" height="28" rx="6" fill="var(--diagram-accent)" opacity="0.25"/>
    <text x="285" y="136" text-anchor="middle" font-size="11" fill="var(--diagram-accent)">paused &#183; lease expires</text>

    <!-- grant token 34 to client 2 -->
    <line x1="400" y1="52" x2="420" y2="196" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <path d="M 420 196 l -7 -4 l 5 -6 z" fill="var(--diagram-stroke)"/>
    <rect x="424" y="64" width="92" height="20" rx="4" fill="var(--diagram-fill)" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="470" y="78" text-anchor="middle" font-size="11" fill="var(--diagram-stroke)">lease, token 34</text>

    <!-- client 2 write with token 34 -->
    <line x1="450" y1="202" x2="480" y2="266" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <path d="M 480 266 l -8 -3 l 4 -7 z" fill="var(--diagram-stroke)"/>
    <text x="487" y="232" font-size="11" fill="var(--diagram-stroke)">write (token 34)</text>
    <text x="480" y="290" font-size="11" font-weight="600" fill="var(--diagram-stroke)" text-anchor="middle">accepted &#10003;</text>

    <!-- client 1 wakes, writes with token 33 -->
    <rect x="540" y="118" width="120" height="28" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="600" y="136" text-anchor="middle" font-size="11" fill="var(--diagram-accent)">wakes up (zombie)</text>
    <line x1="630" y1="146" x2="655" y2="266" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <path d="M 655 266 l -7 -5 l 5 -6 z" fill="var(--diagram-accent)"/>
    <text x="636" y="216" text-anchor="end" font-size="11" fill="var(--diagram-accent)">write (token 33)</text>
    <text x="660" y="290" font-size="11" font-weight="600" fill="var(--diagram-accent)" text-anchor="middle">rejected: 33 &#60; 34</text>
  </svg>
</Diagram>
