---
import Diagram from '../Diagram.astro';

// Event-time lane: steady stream of events
const eventDots = Array.from({ length: 14 }, (_, i) => 90 + i * 44);
// Processing-time lane: normal, then a gap (restart), then a burst
const procDots = [90, 134, 178, 222, 266, 486, 500, 514, 528, 542, 556, 570, 610, 654];
---

<Diagram caption="The same steady stream of events seen in event time (when they happened) and processing time (when the processor got to them). A one-minute restart turns into a phantom spike if you window by processing time.">
  <svg viewBox="0 0 720 280" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="timeskew-title">
    <title id="timeskew-title">Event time versus processing time, showing a backlog burst after a processor restart</title>

    <!-- Event time lane -->
    <text x="20" y="34" font-size="12" font-weight="600" fill="var(--diagram-stroke)">event time</text>
    <text x="130" y="34" font-size="11" fill="var(--diagram-muted)">(requests actually arrive at a steady rate)</text>
    <line x1="80" y1="60" x2="700" y2="60" stroke="var(--diagram-stroke)" stroke-width="1.5" marker-end="url(#ts-arrow)"/>
    {eventDots.map((x) => <circle cx={x} cy={60} r="5" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>)}

    <!-- mapping arrows suggestion -->
    <line x1="310" y1="74" x2="500" y2="136" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="3 4" marker-end="url(#ts-arrow-muted)"/>
    <text x="240" y="116" font-size="11" fill="var(--diagram-muted)">delayed, processed later</text>

    <!-- Processing time lane -->
    <text x="20" y="158" font-size="12" font-weight="600" fill="var(--diagram-stroke)">processing time</text>
    <line x1="80" y1="184" x2="700" y2="184" stroke="var(--diagram-stroke)" stroke-width="1.5" marker-end="url(#ts-arrow)"/>
    {procDots.map((x, i) => <circle cx={x} cy={184} r="5" fill={i >= 5 && i <= 11 ? 'var(--diagram-accent)' : 'var(--diagram-fill)'} stroke={i >= 5 && i <= 11 ? 'var(--diagram-accent)' : 'var(--diagram-stroke)'} stroke-width="1.5"/>)}

    <!-- restart gap annotation -->
    <rect x="286" y="166" width="186" height="36" rx="6" fill="none" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="4 4"/>
    <text x="379" y="222" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">processor down for redeploy: nothing processed</text>

    <!-- burst annotation -->
    <text x="528" y="152" text-anchor="middle" font-size="11" fill="var(--diagram-accent)">backlog burst: looks like a traffic spike,</text>
    <text x="528" y="166" text-anchor="middle" font-size="11" fill="var(--diagram-accent)">but no spike ever happened</text>

    <text x="20" y="258" font-size="12" fill="var(--diagram-stroke)">window by the timestamp in the event, not by the processor's clock, and the artifact disappears.</text>

    <defs>
      <marker id="ts-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--diagram-stroke)"/>
      </marker>
      <marker id="ts-arrow-muted" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--diagram-muted)"/>
      </marker>
    </defs>
  </svg>
</Diagram>
