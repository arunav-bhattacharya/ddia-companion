---
import Diagram from '../Diagram.astro';

const p0 = [0, 1, 2, 3, 4, 5, 6, 7];
const p1 = [0, 1, 2, 3, 4, 5];
---

<Diagram caption="A topic split into two partitions. Producers append to the end; each consumer group tracks one offset per partition, so the broker never needs per-message acknowledgments.">
  <svg viewBox="0 0 720 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="partlog-title">
    <title id="partlog-title">Partitioned log with two consumer groups at different offsets</title>

    <text x="20" y="28" font-size="13" font-weight="600" fill="var(--diagram-stroke)">topic = a group of partitions, each an append-only log</text>

    <!-- Partition 0 -->
    <text x="20" y="86" font-size="12" fill="var(--diagram-muted)">partition 0</text>
    {
      p0.map((n, i) => (
        <g>
          <rect x={110 + i * 48} y={64} width="40" height="32" rx="4" fill={i === 7 ? 'var(--diagram-accent)' : 'var(--diagram-fill)'} stroke={i === 7 ? 'var(--diagram-accent)' : 'var(--diagram-muted)'} stroke-width="1.5"/>
          <text x={130 + i * 48} y={85} text-anchor="middle" font-size="12" fill={i === 7 ? 'var(--bg)' : 'var(--diagram-stroke)'}>{n}</text>
        </g>
      ))
    }
    <line x1="496" y1="80" x2="528" y2="80" stroke="var(--diagram-accent)" stroke-width="1.5" marker-end="url(#pl-arrow)"/>
    <text x="560" y="84" font-size="11" fill="var(--diagram-accent)">writes append</text>

    <!-- Partition 1 -->
    <text x="20" y="156" font-size="12" fill="var(--diagram-muted)">partition 1</text>
    {
      p1.map((n, i) => (
        <g>
          <rect x={110 + i * 48} y={134} width="40" height="32" rx="4" fill={i === 5 ? 'var(--diagram-accent)' : 'var(--diagram-fill)'} stroke={i === 5 ? 'var(--diagram-accent)' : 'var(--diagram-muted)'} stroke-width="1.5"/>
          <text x={130 + i * 48} y={155} text-anchor="middle" font-size="12" fill={i === 5 ? 'var(--bg)' : 'var(--diagram-stroke)'}>{n}</text>
        </g>
      ))
    }

    <!-- consumer group A marker on partition 0, offset 5 boundary -->
    <line x1="350" y1="56" x2="350" y2="104" stroke="var(--diagram-stroke)" stroke-width="1.5" stroke-dasharray="4 3"/>
    <text x="350" y="48" text-anchor="middle" font-size="11" fill="var(--diagram-stroke)">group A: offset 5</text>

    <!-- consumer group B marker on partition 1, offset 3 boundary -->
    <line x1="254" y1="126" x2="254" y2="174" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="4 3"/>
    <text x="254" y="190" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">group B: offset 3</text>

    <!-- explanation rows -->
    <text x="20" y="232" font-size="12" fill="var(--diagram-stroke)">behind a group's offset = processed; ahead of it = not yet seen.</text>
    <text x="20" y="254" font-size="12" fill="var(--diagram-muted)">groups are independent: B can lag, replay, or restart from 0 without affecting A.</text>
    <text x="20" y="276" font-size="12" fill="var(--diagram-muted)">ordering is guaranteed within a partition only — same key, same partition.</text>

    <defs>
      <marker id="pl-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--diagram-accent)"/>
      </marker>
    </defs>
  </svg>
</Diagram>
