---
import Diagram from '../Diagram.astro';
---

<Diagram caption="Write skew: each doctor's transaction checks the same condition (two doctors on call), then updates a different row — both commit, and the hospital's at-least-one-on-call invariant is broken.">
  <svg viewBox="0 0 720 280" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="writeskew-title">
    <title id="writeskew-title">Two concurrent transactions each reading that two doctors are on call, then each taking a different doctor off call, leaving zero on call</title>

    <!-- lane labels -->
    <text x="20" y="64" font-size="12" fill="var(--diagram-muted)">Aaliyah&#8217;s txn</text>
    <text x="20" y="144" font-size="12" fill="var(--diagram-muted)">Bryce&#8217;s txn</text>

    <!-- Aaliyah -->
    <rect x="130" y="44" width="190" height="28" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="225" y="63" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">on-call count? &#8594; 2 &#10003;</text>
    <rect x="360" y="44" width="200" height="28" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="460" y="63" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">set Aaliyah off call</text>
    <text x="600" y="63" font-size="12" fill="var(--diagram-stroke)">commit</text>

    <!-- Bryce -->
    <rect x="160" y="124" width="190" height="28" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="255" y="143" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">on-call count? &#8594; 2 &#10003;</text>
    <rect x="390" y="124" width="200" height="28" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="490" y="143" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">set Bryce off call</text>
    <text x="630" y="143" font-size="12" fill="var(--diagram-stroke)">commit</text>

    <!-- annotation: snapshots -->
    <text x="130" y="98" font-size="11" fill="var(--diagram-muted)">both reads come from snapshots taken before either write &#8212; each sees the other still on call</text>

    <!-- outcome -->
    <rect x="130" y="200" width="460" height="44" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="360" y="222" text-anchor="middle" font-size="12" font-weight="600" fill="var(--diagram-accent)">result: zero doctors on call</text>
    <text x="360" y="238" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">invariant &#8220;at least one doctor on call&#8221; violated, yet no row was written by both</text>
  </svg>
</Diagram>
