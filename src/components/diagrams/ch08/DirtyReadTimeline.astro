---
import Diagram from '../Diagram.astro';
---

<Diagram caption="Read committed prevents dirty reads: while user 1's transaction is uncommitted, user 2 keeps seeing the old value of x; the new value becomes visible only at the moment of commit.">
  <svg viewBox="0 0 720 250" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="dirtyread-title">
    <title id="dirtyread-title">Timeline showing a reader receiving the old committed value until the writer's transaction commits</title>

    <!-- lane labels -->
    <text x="20" y="74" font-size="12" fill="var(--diagram-muted)">user 1 (writer)</text>
    <text x="20" y="164" font-size="12" fill="var(--diagram-muted)">user 2 (reader)</text>

    <!-- writer transaction bar -->
    <rect x="150" y="52" width="310" height="32" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="165" y="73" font-size="12" fill="var(--diagram-stroke)">set x = 3 (uncommitted)</text>

    <!-- commit marker -->
    <line x1="460" y1="40" x2="460" y2="215" stroke="var(--diagram-accent)" stroke-width="1.5" stroke-dasharray="4 3"/>
    <text x="460" y="32" text-anchor="middle" font-size="12" font-weight="600" fill="var(--diagram-accent)">commit</text>

    <!-- reader events -->
    <rect x="220" y="146" width="110" height="28" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="275" y="165" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">get x &#8594; 2</text>
    <text x="275" y="195" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">old committed value</text>

    <rect x="530" y="146" width="110" height="28" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="585" y="165" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">get x &#8594; 3</text>
    <text x="585" y="195" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">new value, now visible</text>

    <!-- time axis -->
    <line x1="150" y1="225" x2="680" y2="225" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <polygon points="680,225 670,220 670,230" fill="var(--diagram-muted)"/>
    <text x="680" y="213" text-anchor="end" font-size="11" fill="var(--diagram-muted)">time</text>
  </svg>
</Diagram>
