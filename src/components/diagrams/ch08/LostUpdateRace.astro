---
import Diagram from '../Diagram.astro';
---

<Diagram caption="A lost update: both clients read counter = 42, both compute 43, and the second write clobbers the first — two increments happened but the counter only moved by one.">
  <svg viewBox="0 0 720 260" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="lostupdate-title">
    <title id="lostupdate-title">Two clients performing concurrent read-modify-write cycles on a counter, where one increment is lost</title>

    <!-- lane labels -->
    <text x="20" y="64" font-size="12" fill="var(--diagram-muted)">client A</text>
    <text x="20" y="134" font-size="12" fill="var(--diagram-muted)">client B</text>
    <text x="20" y="212" font-size="12" fill="var(--diagram-muted)">counter</text>

    <!-- client A events -->
    <rect x="120" y="44" width="120" height="28" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="180" y="63" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">read &#8594; 42</text>
    <rect x="330" y="44" width="120" height="28" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="390" y="63" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">write 43</text>

    <!-- client B events -->
    <rect x="180" y="114" width="120" height="28" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="240" y="133" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">read &#8594; 42</text>
    <rect x="470" y="114" width="120" height="28" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="530" y="133" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">write 43</text>

    <text x="470" y="166" font-size="11" fill="var(--diagram-accent)">clobbers A&#8217;s write &#8212; B never saw 43</text>

    <!-- counter state -->
    <line x1="120" y1="208" x2="680" y2="208" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <text x="160" y="232" font-size="12" fill="var(--diagram-stroke)">42</text>
    <text x="390" y="232" font-size="12" fill="var(--diagram-stroke)">43</text>
    <text x="530" y="232" font-size="12" font-weight="600" fill="var(--diagram-accent)">43 (should be 44)</text>
  </svg>
</Diagram>
