---
import Diagram from '../Diagram.astro';
---

<Diagram caption="Looking up key 437 in a B-tree: each page narrows the key range, and with a branching factor in the hundreds, three or four hops reach any key in a multi-terabyte database.">
  <svg viewBox="0 0 720 360" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="btree-title">
    <title id="btree-title">A three-level B-tree with the lookup path for key 437 highlighted</title>

    <text x="410" y="18" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-accent)">find key 437</text>

    <!-- Level labels -->
    <text x="30" y="62" font-size="12" fill="var(--diagram-muted)">root page</text>
    <text x="30" y="172" font-size="12" fill="var(--diagram-muted)">interior page</text>
    <text x="30" y="302" font-size="12" fill="var(--diagram-muted)">leaf page</text>

    <!-- Root page -->
    <rect x="180" y="32" width="360" height="50" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="260" y="62" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">100</text>
    <text x="360" y="62" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">300</text>
    <text x="460" y="62" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">500</text>

    <!-- Child stubs from root (muted) -->
    <line x1="215" y1="82" x2="215" y2="112" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <line x1="310" y1="82" x2="310" y2="112" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <line x1="505" y1="82" x2="505" y2="112" stroke="var(--diagram-muted)" stroke-width="1.5"/>

    <!-- Accent path root -> interior (range 300–500) -->
    <line x1="410" y1="82" x2="374" y2="134" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="368,131 371,143 378,137" fill="var(--diagram-accent)"/>
    <text x="430" y="128" font-size="12" fill="var(--diagram-accent)">300 ≤ 437 &lt; 500</text>

    <!-- Interior page -->
    <rect x="160" y="142" width="400" height="50" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="240" y="172" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">310</text>
    <text x="320" y="172" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">370</text>
    <text x="400" y="172" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">430</text>
    <text x="480" y="172" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">470</text>

    <!-- Child stubs from interior (muted) -->
    <line x1="200" y1="192" x2="200" y2="222" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <line x1="280" y1="192" x2="280" y2="222" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <line x1="360" y1="192" x2="360" y2="222" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <line x1="520" y1="192" x2="520" y2="222" stroke="var(--diagram-muted)" stroke-width="1.5"/>

    <!-- Accent path interior -> leaf (range 430–470) -->
    <line x1="440" y1="192" x2="396" y2="262" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="390,258 393,271 400,264" fill="var(--diagram-accent)"/>
    <text x="455" y="238" font-size="12" fill="var(--diagram-accent)">430 ≤ 437 &lt; 470</text>

    <!-- Leaf page -->
    <rect x="220" y="270" width="320" height="50" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="270" y="300" text-anchor="middle" font-size="14" fill="var(--diagram-stroke)">431</text>
    <text x="325" y="300" text-anchor="middle" font-size="14" fill="var(--diagram-stroke)">433</text>
    <rect x="356" y="278" width="50" height="34" rx="4" fill="var(--diagram-accent)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="381" y="300" text-anchor="middle" font-size="14" font-weight="600" fill="var(--bg)">437</text>
    <text x="437" y="300" text-anchor="middle" font-size="14" fill="var(--diagram-stroke)">440</text>
    <text x="492" y="300" text-anchor="middle" font-size="14" fill="var(--diagram-stroke)">445</text>

    <text x="380" y="344" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">leaf pages hold the values (or references to where they live)</text>

    <!-- Side annotation -->
    <text x="580" y="56" font-size="11" fill="var(--diagram-muted)">branching factor:</text>
    <text x="580" y="71" font-size="11" fill="var(--diagram-muted)">several hundred</text>
    <text x="580" y="166" font-size="11" fill="var(--diagram-muted)">3–4 levels reach</text>
    <text x="580" y="181" font-size="11" fill="var(--diagram-muted)">hundreds of TB</text>
  </svg>
</Diagram>
