---
import Diagram from '../Diagram.astro';
---

<Diagram caption="The LSM write path: every write lands in the memtable and the write-ahead log; full memtables are flushed as immutable SSTable segments, which background compaction merges, keeping only the newest value per key.">
  <svg viewBox="0 0 720 400" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="lsm-title">
    <title id="lsm-title">LSM-tree write path from memtable through SSTable segments to a compacted segment</title>

    <!-- Incoming writes -->
    <text x="40" y="67" font-size="13" font-weight="600" fill="var(--diagram-stroke)">writes</text>
    <line x1="86" y1="62" x2="132" y2="62" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <polygon points="132,57 142,62 132,67" fill="var(--diagram-stroke)"/>

    <!-- Memtable -->
    <rect x="142" y="35" width="200" height="55" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="242" y="58" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">Memtable</text>
    <text x="242" y="76" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">sorted in-memory map</text>

    <!-- WAL -->
    <rect x="452" y="35" width="230" height="55" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="567" y="58" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">Write-ahead log</text>
    <text x="567" y="76" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">replayed after a crash</text>

    <!-- Arrow memtable -> WAL -->
    <line x1="342" y1="62" x2="442" y2="62" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <polygon points="442,57 452,62 442,67" fill="var(--diagram-muted)"/>
    <text x="396" y="50" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">also appended</text>

    <!-- memory / disk divider -->
    <line x1="20" y1="130" x2="700" y2="130" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="6 5"/>
    <text x="698" y="121" text-anchor="end" font-size="12" fill="var(--diagram-muted)">memory</text>
    <text x="698" y="149" text-anchor="end" font-size="12" fill="var(--diagram-muted)">disk</text>

    <!-- Flush arrow -->
    <line x1="200" y1="90" x2="200" y2="160" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="195,160 200,170 205,160" fill="var(--diagram-accent)"/>
    <text x="212" y="156" font-size="12" fill="var(--diagram-accent)">flush when full (a few MB)</text>

    <!-- SSTable segments -->
    <rect x="80" y="170" width="240" height="44" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="200" y="197" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">SSTable segment — newest</text>

    <rect x="80" y="224" width="240" height="44" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="200" y="251" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">SSTable segment</text>

    <rect x="80" y="278" width="240" height="44" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="200" y="305" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">SSTable segment — oldest</text>

    <text x="200" y="345" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">immutable, sorted by key</text>

    <!-- Compaction arrows -->
    <line x1="320" y1="192" x2="422" y2="238" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="418,231 432,242 422,246" fill="var(--diagram-accent)"/>
    <line x1="320" y1="246" x2="422" y2="250" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="422,245 432,250 422,255" fill="var(--diagram-accent)"/>
    <line x1="320" y1="300" x2="422" y2="262" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="421,269 432,258 425,254" fill="var(--diagram-accent)"/>
    <text x="376" y="330" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">background</text>
    <text x="376" y="346" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">compaction</text>

    <!-- Compacted segment -->
    <rect x="432" y="215" width="250" height="70" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="557" y="243" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">Compacted segment</text>
    <text x="557" y="263" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">one value per key, tombstones dropped</text>
  </svg>
</Diagram>
