---
import Diagram from '../Diagram.astro';
---

<Diagram caption="A quorum that isn't linearizable: with n = 3, w = 3, r = 2, reader B starts after reader A has finished, yet B returns the old value while A saw the new one." wide>
  <svg viewBox="0 0 740 330" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="quorumrace-title">
    <title id="quorumrace-title">Timeline of a write reaching three replicas at different times, with two quorum reads observing inconsistent values</title>

    <!-- Writer label -->
    <text x="40" y="38" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Write x = 1 sent to all replicas (w = 3) — but it arrives at different times:</text>

    <!-- Replica rows -->
    <g font-size="13" font-weight="600" fill="var(--diagram-stroke)">
      <text x="40" y="95">Replica 1</text>
      <text x="40" y="165">Replica 2</text>
      <text x="40" y="235">Replica 3</text>
    </g>

    <!-- Lifelines -->
    <line x1="140" y1="90" x2="690" y2="90" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <line x1="140" y1="160" x2="690" y2="160" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <line x1="140" y1="230" x2="690" y2="230" stroke="var(--diagram-stroke)" stroke-width="1.5"/>

    <!-- Arrival markers: value flips 0 -> 1 -->
    <circle cx="210" cy="90" r="6" fill="var(--diagram-accent)"/>
    <text x="210" y="76" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">x: 0 → 1</text>
    <circle cx="600" cy="160" r="6" fill="var(--diagram-accent)"/>
    <text x="600" y="146" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">x: 0 → 1 (late)</text>
    <circle cx="645" cy="230" r="6" fill="var(--diagram-accent)"/>
    <text x="645" y="216" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">x: 0 → 1 (late)</text>

    <!-- Reader A: vertical dashed line spanning replicas 1 and 2 -->
    <line x1="320" y1="70" x2="320" y2="180" stroke="var(--diagram-stroke)" stroke-width="1.5" stroke-dasharray="5 4"/>
    <text x="320" y="60" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Reader A (r = 2)</text>
    <text x="320" y="198" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">reads R1 = 1, R2 = 0 ⇒ returns 1</text>

    <!-- Reader B: vertical dashed line spanning replicas 2 and 3 -->
    <line x1="470" y1="140" x2="470" y2="250" stroke="var(--diagram-accent)" stroke-width="1.5" stroke-dasharray="5 4"/>
    <text x="470" y="130" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-accent)">Reader B (r = 2), starts after A finished</text>
    <text x="470" y="268" text-anchor="middle" font-size="12" fill="var(--diagram-accent)">reads R2 = 0, R3 = 0 ⇒ returns 0 — stale!</text>

    <!-- Time axis -->
    <line x1="140" y1="295" x2="690" y2="295" stroke="var(--diagram-muted)" stroke-width="1.5"/>
    <polygon points="690,290 700,295 690,300" fill="var(--diagram-muted)"/>
    <text x="415" y="318" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">time → (w + r &gt; n is satisfied, yet the execution is not linearizable)</text>
  </svg>
</Diagram>
