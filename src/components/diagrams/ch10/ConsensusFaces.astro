---
import Diagram from '../Diagram.astro';
---

<Diagram caption="The many faces of consensus: solve any one of these problems in a fault-tolerant way and you can convert it into a solution for all the others.">
  <svg viewBox="0 0 720 390" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="consensusfaces-title">
    <title id="consensusfaces-title">Consensus at the center, with equivalent problems arranged around it</title>

    <!-- Connector lines (drawn first, under the boxes) -->
    <g stroke="var(--diagram-muted)" stroke-width="1.5">
      <line x1="200" y1="86" x2="305" y2="160"/>
      <line x1="520" y1="86" x2="415" y2="160"/>
      <line x1="120" y1="195" x2="270" y2="195"/>
      <line x1="600" y1="195" x2="450" y2="195"/>
      <line x1="200" y1="304" x2="305" y2="230"/>
      <line x1="520" y1="304" x2="415" y2="230"/>
    </g>

    <!-- Center -->
    <rect x="270" y="160" width="180" height="70" rx="8" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="360" y="190" text-anchor="middle" font-size="15" font-weight="600" fill="var(--diagram-stroke)">Consensus</text>
    <text x="360" y="210" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">nodes agree on a value</text>

    <!-- Satellites -->
    <g>
      <rect x="60" y="30" width="190" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="155" y="53" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Linearizable CAS</text>
      <text x="155" y="71" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">compare-and-set a register</text>

      <rect x="470" y="30" width="200" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="570" y="53" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Shared log</text>
      <text x="570" y="71" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">total order broadcast</text>

      <rect x="20" y="167" width="160" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="100" y="190" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Locks &amp; leases</text>
      <text x="100" y="208" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">leader election</text>

      <rect x="540" y="167" width="160" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="620" y="190" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Atomic commit</text>
      <text x="620" y="208" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">all commit or all abort</text>

      <rect x="60" y="304" width="190" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="155" y="327" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Uniqueness constraints</text>
      <text x="155" y="345" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">one winner per username</text>

      <rect x="470" y="304" width="200" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-muted)" stroke-width="1.5"/>
      <text x="570" y="327" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-muted)">Fetch-and-add</text>
      <text x="570" y="345" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">only solves it for 2 proposers</text>
    </g>
  </svg>
</Diagram>
