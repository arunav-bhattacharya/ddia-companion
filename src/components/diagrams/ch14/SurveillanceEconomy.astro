---
import Diagram from '../Diagram.astro';
---

<Diagram wide caption="Follow the money: in an advertising-funded service the advertiser is the customer, and your behavioral data flows to places you never see.">
  <svg viewBox="0 0 760 380" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ch14-surv-title">
    <title id="ch14-surv-title">Behavioral data flowing from a user through a free service out to advertisers, data brokers, governments, and attackers, with money flowing back from advertisers</title>
    <defs>
      <marker id="ch14-surv-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--diagram-stroke)"/>
      </marker>
      <marker id="ch14-surv-arrow-accent" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--diagram-accent)"/>
      </marker>
      <marker id="ch14-surv-arrow-muted" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--diagram-muted)"/>
      </marker>
    </defs>

    <!-- User -->
    <rect x="20" y="150" width="150" height="70" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="95" y="180" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">You</text>
    <text x="95" y="200" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">user of a free service</text>

    <!-- Service -->
    <rect x="270" y="140" width="190" height="90" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="365" y="175" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">The service</text>
    <text x="365" y="195" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">builds profiles and</text>
    <text x="365" y="211" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">predictions about you</text>

    <!-- You -> service -->
    <line x1="170" y1="170" x2="262" y2="170" stroke="var(--diagram-stroke)" stroke-width="1.5" marker-end="url(#ch14-surv-arrow)"/>
    <text x="216" y="142" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">clicks, location,</text>
    <text x="216" y="158" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">purchases, contacts</text>

    <!-- Service -> you (dashed) -->
    <line x1="262" y1="205" x2="178" y2="205" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="5 4" marker-end="url(#ch14-surv-arrow-muted)"/>
    <text x="216" y="232" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">free features,</text>
    <text x="216" y="248" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">engagement loops</text>

    <!-- Advertisers (the customer) -->
    <rect x="560" y="24" width="180" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="650" y="47" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Advertisers</text>
    <text x="650" y="66" text-anchor="middle" font-size="12" fill="var(--diagram-accent)">the paying customer</text>

    <!-- Data brokers -->
    <rect x="560" y="116" width="180" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="650" y="139" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Data brokers</text>
    <text x="650" y="158" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">buy, merge, resell</text>

    <!-- Governments -->
    <rect x="560" y="208" width="180" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="650" y="231" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Governments</text>
    <text x="650" y="250" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">request, compel, seize</text>

    <!-- Attackers -->
    <rect x="560" y="300" width="180" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="650" y="323" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Attackers</text>
    <text x="650" y="342" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">breaches happen</text>

    <!-- Service -> advertisers (targeting), accent -->
    <line x1="455" y1="150" x2="552" y2="62" stroke="var(--diagram-accent)" stroke-width="1.5" marker-end="url(#ch14-surv-arrow-accent)"/>
    <text x="476" y="84" text-anchor="middle" font-size="12" fill="var(--diagram-accent)">ad targeting</text>

    <!-- Advertisers -> service (money), accent -->
    <line x1="565" y1="90" x2="475" y2="148" stroke="var(--diagram-accent)" stroke-width="1.5" stroke-dasharray="5 4" marker-end="url(#ch14-surv-arrow-accent)"/>
    <text x="540" y="126" text-anchor="middle" font-size="12" font-weight="600" fill="var(--diagram-accent)">money</text>

    <!-- Service -> brokers -->
    <line x1="460" y1="172" x2="552" y2="150" stroke="var(--diagram-stroke)" stroke-width="1.5" marker-end="url(#ch14-surv-arrow)"/>

    <!-- Service -> governments -->
    <line x1="460" y1="206" x2="552" y2="228" stroke="var(--diagram-stroke)" stroke-width="1.5" marker-end="url(#ch14-surv-arrow)"/>

    <!-- Service -> attackers (dashed) -->
    <line x1="450" y1="228" x2="552" y2="316" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="5 4" marker-end="url(#ch14-surv-arrow-muted)"/>
  </svg>
</Diagram>
