---
import Diagram from '../Diagram.astro';
---

<Diagram caption="A self-reinforcing feedback loop: using credit scores to screen job applicants turns one stroke of bad luck into a downward spiral.">
  <svg viewBox="0 0 720 350" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ch14-loop-title">
    <title id="ch14-loop-title">Four-stage feedback loop between missed payments, a falling credit score, rejected job applications, and falling income</title>
    <defs>
      <marker id="ch14-loop-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--diagram-accent)"/>
      </marker>
    </defs>

    <!-- Top: misfortune -->
    <rect x="250" y="16" width="220" height="60" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="360" y="41" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">Missed bill payments</text>
    <text x="360" y="60" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">illness, layoff — plain bad luck</text>

    <!-- Right: score drops -->
    <rect x="495" y="145" width="205" height="60" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="597" y="170" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">Credit score drops</text>
    <text x="597" y="189" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">the data faithfully records it</text>

    <!-- Bottom: rejections -->
    <rect x="250" y="274" width="220" height="60" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="360" y="299" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">Job applications rejected</text>
    <text x="360" y="318" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">employers screen by credit score</text>

    <!-- Left: income falls -->
    <rect x="20" y="145" width="205" height="60" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="122" y="170" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">Income falls further</text>
    <text x="122" y="189" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">more bills go unpaid</text>

    <!-- Clockwise arrows -->
    <line x1="474" y1="64" x2="553" y2="142" stroke="var(--diagram-accent)" stroke-width="1.5" marker-end="url(#ch14-loop-arrow)"/>
    <line x1="558" y1="208" x2="476" y2="282" stroke="var(--diagram-accent)" stroke-width="1.5" marker-end="url(#ch14-loop-arrow)"/>
    <line x1="246" y1="286" x2="164" y2="210" stroke="var(--diagram-accent)" stroke-width="1.5" marker-end="url(#ch14-loop-arrow)"/>
    <line x1="160" y1="142" x2="244" y2="68" stroke="var(--diagram-accent)" stroke-width="1.5" marker-end="url(#ch14-loop-arrow)"/>

    <!-- Center annotation -->
    <text x="360" y="168" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">each pass around the loop</text>
    <text x="360" y="186" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">digs the hole deeper</text>
  </svg>
</Diagram>
