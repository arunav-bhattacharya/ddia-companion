---
import Diagram from '../Diagram.astro';
---

<Diagram wide caption="The same résumé shredded across normalized tables with foreign keys (left) versus stored as one self-contained JSON document (right).">
  <svg viewBox="0 0 780 380" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="normdoc-title">
    <title id="normdoc-title">A résumé represented as three relational tables versus a single JSON document</title>

    <!-- Left: relational tables -->
    <text x="180" y="26" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">Relational (shredded)</text>

    <!-- users table -->
    <rect x="80" y="42" width="200" height="78" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="180" y="62" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">users</text>
    <line x1="92" y1="70" x2="268" y2="70" stroke="var(--diagram-muted)" stroke-width="1"/>
    <text x="100" y="88" font-size="12" fill="var(--diagram-stroke)">user_id: 251</text>
    <text x="100" y="106" font-size="12" fill="var(--diagram-stroke)">name: Priya Nair</text>

    <!-- positions table -->
    <rect x="20" y="210" width="210" height="96" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="125" y="230" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">positions</text>
    <line x1="32" y1="238" x2="218" y2="238" stroke="var(--diagram-muted)" stroke-width="1"/>
    <text x="40" y="256" font-size="12" fill="var(--diagram-stroke)">user_id: 251 · Engineer</text>
    <text x="40" y="274" font-size="12" fill="var(--diagram-stroke)">user_id: 251 · CTO</text>
    <text x="40" y="292" font-size="12" fill="var(--diagram-muted)">one row per job</text>

    <!-- education table -->
    <rect x="250" y="210" width="210" height="96" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="355" y="230" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">education</text>
    <line x1="262" y1="238" x2="448" y2="238" stroke="var(--diagram-muted)" stroke-width="1"/>
    <text x="270" y="256" font-size="12" fill="var(--diagram-stroke)">user_id: 251 · IIT Madras</text>
    <text x="270" y="274" font-size="12" fill="var(--diagram-stroke)">user_id: 251 · TU Delft</text>
    <text x="270" y="292" font-size="12" fill="var(--diagram-muted)">one row per degree</text>

    <!-- FK arrows -->
    <line x1="125" y1="210" x2="160" y2="128" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <polygon points="158,131 162,120 166,131" fill="var(--diagram-stroke)" transform="rotate(22 162 126)"/>
    <line x1="355" y1="210" x2="210" y2="126" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <polygon points="206,130 202,119 214,122" fill="var(--diagram-stroke)"/>
    <text x="252" y="170" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">foreign key: user_id</text>
    <text x="252" y="186" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">(join to reassemble)</text>

    <!-- Right: JSON document -->
    <text x="630" y="26" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">Document (one tree)</text>
    <rect x="510" y="42" width="240" height="290" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="528" y="70" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">&#123;</text>
    <text x="544" y="92" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">"user_id": 251,</text>
    <text x="544" y="114" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">"name": "Priya Nair",</text>
    <text x="544" y="136" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">"positions": [</text>
    <text x="560" y="158" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">&#123; "Engineer", … &#125;,</text>
    <text x="560" y="180" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">&#123; "CTO", … &#125;</text>
    <text x="544" y="202" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">],</text>
    <text x="544" y="224" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">"education": [</text>
    <text x="560" y="246" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">&#123; "IIT Madras", … &#125;,</text>
    <text x="560" y="268" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">&#123; "TU Delft", … &#125;</text>
    <text x="544" y="290" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">]</text>
    <text x="528" y="312" font-size="12" font-family="monospace" fill="var(--diagram-stroke)">&#125;</text>

    <text x="630" y="356" text-anchor="middle" font-size="12" fill="var(--diagram-accent)">one read fetches everything (locality)</text>
    <text x="240" y="340" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">three lookups or a multiway join per profile</text>
  </svg>
</Diagram>
