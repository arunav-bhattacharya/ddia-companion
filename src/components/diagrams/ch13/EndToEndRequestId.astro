---
import Diagram from '../Diagram.astro';
---

<Diagram caption="Only an identifier minted at the endpoint survives every retry: the browser generates the request ID, and a uniqueness constraint in the database suppresses the duplicate.">
  <svg viewBox="0 0 740 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="e2e-request-id-title">
    <title id="e2e-request-id-title">End-to-end duplicate suppression using a client-generated request ID</title>

    <!-- Browser -->
    <rect x="20" y="100" width="160" height="84" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="100" y="128" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Browser</text>
    <text x="100" y="148" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">generates request ID</text>
    <text x="100" y="166" text-anchor="middle" font-size="12" fill="var(--diagram-accent)">a1b2</text>

    <!-- First POST -->
    <line x1="180" y1="124" x2="266" y2="124" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <polygon points="266,119 276,124 266,129" fill="var(--diagram-stroke)"/>
    <text x="228" y="112" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">POST (ID a1b2)</text>

    <!-- Retry POST -->
    <line x1="180" y1="166" x2="266" y2="166" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="5 4"/>
    <polygon points="266,161 276,166 266,171" fill="var(--diagram-muted)"/>
    <text x="228" y="188" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">timeout → retry</text>
    <text x="228" y="203" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">(same ID a1b2)</text>

    <!-- App server -->
    <rect x="280" y="100" width="150" height="84" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="355" y="136" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">App server</text>
    <text x="355" y="156" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">passes the ID through</text>

    <!-- Inserts -->
    <line x1="430" y1="124" x2="516" y2="124" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <polygon points="516,119 526,124 516,129" fill="var(--diagram-stroke)"/>
    <text x="473" y="112" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">INSERT a1b2</text>

    <line x1="430" y1="166" x2="516" y2="166" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="5 4"/>
    <polygon points="516,161 526,166 516,171" fill="var(--diagram-muted)"/>
    <text x="473" y="188" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">INSERT a1b2 again</text>

    <!-- Database -->
    <rect x="530" y="84" width="190" height="116" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="625" y="110" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Database</text>
    <text x="625" y="130" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">UNIQUE (request_id)</text>
    <text x="625" y="156" text-anchor="middle" font-size="12" fill="var(--diagram-accent)">first insert: applied</text>
    <text x="625" y="176" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">duplicate: rejected</text>

    <text x="370" y="248" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">TCP dedupes within a connection; transactions dedupe within a session.</text>
    <text x="370" y="266" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">Only the end-to-end ID dedupes across the whole journey.</text>
  </svg>
</Diagram>
