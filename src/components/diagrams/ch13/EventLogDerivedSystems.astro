---
import Diagram from '../Diagram.astro';
---

<Diagram caption="One ordered event log acts as the system of record; every other representation is derived from it and can be rebuilt by replaying the log.">
  <svg viewBox="0 0 720 330" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="eventlog-derived-title">
    <title id="eventlog-derived-title">An event log feeding several derived data systems</title>

    <!-- Writes coming in -->
    <text x="30" y="140" font-size="12" fill="var(--diagram-muted)">writes</text>
    <line x1="20" y1="160" x2="72" y2="160" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <polygon points="72,155 82,160 72,165" fill="var(--diagram-stroke)"/>

    <!-- Event log -->
    <rect x="86" y="118" width="190" height="84" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="181" y="142" text-anchor="middle" font-size="14" font-weight="600" fill="var(--diagram-stroke)">Event log</text>
    <text x="181" y="159" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">system of record</text>
    <!-- log segments -->
    <g stroke="var(--diagram-stroke)" stroke-width="1.5" fill="var(--bg)">
      <rect x="106" y="170" width="34" height="20" rx="4"/>
      <rect x="144" y="170" width="34" height="20" rx="4"/>
      <rect x="182" y="170" width="34" height="20" rx="4"/>
      <rect x="220" y="170" width="34" height="20" rx="4"/>
    </g>
    <g font-size="11" fill="var(--diagram-muted)" text-anchor="middle">
      <text x="123" y="184">e1</text>
      <text x="161" y="184">e2</text>
      <text x="199" y="184">e3</text>
      <text x="237" y="184">e4</text>
    </g>

    <!-- Derived systems -->
    <g>
      <rect x="480" y="20" width="220" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="590" y="44" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Search index</text>
      <text x="590" y="62" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">derived — rebuildable</text>

      <rect x="480" y="98" width="220" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="590" y="122" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Cache / materialized view</text>
      <text x="590" y="140" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">derived — rebuildable</text>

      <rect x="480" y="176" width="220" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="590" y="200" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">Data warehouse</text>
      <text x="590" y="218" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">derived — rebuildable</text>

      <rect x="480" y="254" width="220" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
      <text x="590" y="278" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">ML model / notifications</text>
      <text x="590" y="296" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">derived — rebuildable</text>
    </g>

    <!-- Fan-out arrows -->
    <g stroke="var(--diagram-accent)" stroke-width="1.5">
      <line x1="276" y1="140" x2="470" y2="50"/>
      <line x1="276" y1="152" x2="470" y2="126"/>
      <line x1="276" y1="168" x2="470" y2="204"/>
      <line x1="276" y1="180" x2="470" y2="282"/>
    </g>
    <g fill="var(--diagram-accent)">
      <polygon points="468,44 480,48 470,56"/>
      <polygon points="467,120 479,126 468,132"/>
      <polygon points="468,198 480,204 467,210"/>
      <polygon points="470,276 480,284 468,288"/>
    </g>

    <text x="370" y="280" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">deterministic derivation functions,</text>
    <text x="370" y="296" text-anchor="middle" font-size="12" fill="var(--diagram-muted)">applied in log order</text>
  </svg>
</Diagram>
