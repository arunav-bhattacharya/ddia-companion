---
import Diagram from '../Diagram.astro';
---

<Diagram caption="Single-leader replication: writes go to one designated node, which streams every change to its followers; reads can be served by any replica.">
  <svg viewBox="0 0 720 310" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="slf-title">
    <title id="slf-title">A writing client sends writes to the leader, which streams changes to two followers; a reading client can read from any replica</title>

    <!-- Writing client -->
    <rect x="20" y="55" width="150" height="60" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="95" y="81" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">writing client</text>
    <text x="95" y="100" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">UPDATE profile …</text>

    <!-- Leader -->
    <rect x="280" y="55" width="150" height="60" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="355" y="81" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">leader</text>
    <text x="355" y="100" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">accepts all writes</text>

    <!-- Followers -->
    <rect x="540" y="20" width="160" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="620" y="43" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">follower 1</text>
    <text x="620" y="61" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">read-only</text>

    <rect x="540" y="110" width="160" height="56" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="620" y="133" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">follower 2</text>
    <text x="620" y="151" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">read-only</text>

    <!-- Write arrow -->
    <line x1="170" y1="85" x2="270" y2="85" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <polygon points="270,80 280,85 270,90" fill="var(--diagram-stroke)"/>
    <text x="220" y="74" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">1. write</text>

    <!-- Replication stream arrows -->
    <line x1="430" y1="72" x2="532" y2="52" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="530,47 541,50 533,58" fill="var(--diagram-accent)"/>
    <line x1="430" y1="98" x2="532" y2="130" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="531,124 540,132 528,134" fill="var(--diagram-accent)"/>
    <text x="483" y="100" text-anchor="middle" font-size="11" fill="var(--diagram-accent)">2. change stream</text>

    <!-- Reading client -->
    <rect x="20" y="215" width="150" height="60" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="95" y="241" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">reading client</text>
    <text x="95" y="260" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">SELECT …</text>

    <!-- Read arrows (dashed) -->
    <line x1="170" y1="235" x2="330" y2="120" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="5 4"/>
    <polygon points="325,118 335,116 331,127" fill="var(--diagram-muted)"/>
    <line x1="170" y1="252" x2="534" y2="158" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="5 4"/>
    <polygon points="528,154 539,156 532,164" fill="var(--diagram-muted)"/>
    <text x="350" y="225" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">3. reads can go to the leader or any follower</text>
  </svg>
</Diagram>
