---
import Diagram from '../Diagram.astro';
---

<Diagram caption="A multi-leader write conflict: two users change the same wiki page title on different leaders; each local write succeeds, and the conflict only surfaces when the changes replicate.">
  <svg viewBox="0 0 720 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="mlc-title">
    <title id="mlc-title">Two leaders accept conflicting updates to the same record and detect the conflict during asynchronous replication</title>

    <!-- Users -->
    <rect x="40" y="20" width="140" height="52" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="110" y="42" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">user 1</text>
    <text x="110" y="60" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">title: A → B</text>

    <rect x="540" y="20" width="140" height="52" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="610" y="42" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">user 2</text>
    <text x="610" y="60" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">title: A → C</text>

    <!-- Arrows users -> leaders -->
    <line x1="110" y1="72" x2="110" y2="112" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <polygon points="105,112 110,122 115,112" fill="var(--diagram-stroke)"/>
    <text x="120" y="100" font-size="11" fill="var(--diagram-muted)">ok ✓</text>

    <line x1="610" y1="72" x2="610" y2="112" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <polygon points="605,112 610,122 615,112" fill="var(--diagram-stroke)"/>
    <text x="620" y="100" font-size="11" fill="var(--diagram-muted)">ok ✓</text>

    <!-- Leaders -->
    <rect x="30" y="122" width="160" height="70" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="110" y="148" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">leader 1 (region A)</text>
    <text x="110" y="170" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">title = “B”</text>

    <rect x="530" y="122" width="160" height="70" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-stroke)" stroke-width="1.5"/>
    <text x="610" y="148" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-stroke)">leader 2 (region B)</text>
    <text x="610" y="170" text-anchor="middle" font-size="12" fill="var(--diagram-stroke)">title = “C”</text>

    <!-- Crossing replication arrows -->
    <line x1="190" y1="145" x2="522" y2="145" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="6 4"/>
    <polygon points="522,140 532,145 522,150" fill="var(--diagram-muted)"/>
    <text x="360" y="135" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">async: “set title to B”</text>

    <line x1="530" y1="172" x2="198" y2="172" stroke="var(--diagram-muted)" stroke-width="1.5" stroke-dasharray="6 4"/>
    <polygon points="198,167 188,172 198,177" fill="var(--diagram-muted)"/>
    <text x="360" y="190" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">async: “set title to C”</text>

    <!-- Conflict box -->
    <rect x="235" y="230" width="250" height="64" rx="6" fill="var(--diagram-fill)" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <text x="360" y="256" text-anchor="middle" font-size="13" font-weight="600" fill="var(--diagram-accent)">conflict: B vs C</text>
    <text x="360" y="276" text-anchor="middle" font-size="11" fill="var(--diagram-muted)">neither write knew about the other</text>

    <!-- Arrows from leaders to conflict -->
    <line x1="140" y1="192" x2="248" y2="232" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="241,232 250,236 245,225" fill="var(--diagram-accent)"/>
    <line x1="580" y1="192" x2="472" y2="232" stroke="var(--diagram-accent)" stroke-width="1.5"/>
    <polygon points="475,225 470,236 479,232" fill="var(--diagram-accent)"/>
  </svg>
</Diagram>
